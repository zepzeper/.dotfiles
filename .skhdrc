# Focus Brave (Option + S)
alt - s : open -a "Brave browser"

# Focus Terminal (Option + T)
alt - z : open -a "Alacritty"

# Focus GIMP (Option + Y)
alt - g : open -a "GIMP"

# Focus Spotify (Option + P)
alt - p : open -a "Spotify"

# Focus TablePlus (Option + P)
alt - d : open -a "TablePlus"

# Focus YTMusic (Option + Y)
alt - y : open -a "Youtube Music"

# Focus Notion (Option + N)
alt - n : open -a "Notion"

# Focus Slack (Option + V)
alt - v : open -a "Slack"

